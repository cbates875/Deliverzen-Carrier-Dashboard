{
  "routes": [
    { "route": "/.auth/login/aad", "allowedRoles": ["anonymous"] },
    { "route": "/.auth/logout", "allowedRoles": ["anonymous"] },
    { "route": "/*", "allowedRoles": ["authorized"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad", "statusCode": 302 }
  }
}
